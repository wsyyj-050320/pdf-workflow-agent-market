# Copy to .env and fill in your values.
# Never commit .env — it is gitignored.

# ── Required ──────────────────────────────────────────────────────────────────

# Free at https://helius.dev (100k credits/month)
HELIUS_API_KEY=your_helius_api_key_here

SOLANA_RPC_URL=https://devnet.helius-rpc.com/?api-key=your_helius_api_key_here
SOLANA_WS_URL=wss://devnet.helius-rpc.com/?api-key=your_helius_api_key_here

# Devnet wallet pubkey that RECEIVES payments (the seller's wallet)
# Get devnet SOL: https://faucet.solana.com
WALLET=

# ── Buyer agent ───────────────────────────────────────────────────────────────

# Anthropic API key — https://console.anthropic.com (free credits available)
# Optional: buyer agent works without it, skips Claude analysis
ANTHROPIC_API_KEY=

# Devnet keypair for the buyer agent to sign payments
# Generate: solana-keygen new --no-bip39-passphrase --outfile buyer-keypair.json
# Then encode: cat buyer-keypair.json | python3 -c "import sys,json,base58; print(base58.b58encode(bytes(json.load(sys.stdin))).decode())"
# Or use: https://www.npmjs.com/package/@solana/web3.js Keypair.generate() in a script
BUYER_KEYPAIR_B58=

# Max SOL the buyer will spend per request (safety cap)
BUYER_MAX_SOL=0.001

# ── Seller config ─────────────────────────────────────────────────────────────

# Price per service request in SOL
PRICE_SOL=0.0001

# Which service the seller provides: jupiter | coingecko | news
# jupiter  — DEX swap quotes (no extra key needed)
# coingecko — crypto prices  (no extra key needed)
# news      — headlines (requires NEWS_API_KEY below)
SERVICE=jupiter

# Jupiter API key — higher rate limits (free at jup.ag/developers)
# Optional: works without it but may hit rate limits under load
JUPITER_API_KEY=

# Required only when SERVICE=news — free at https://newsapi.org
NEWS_API_KEY=

# ── CoralOS ───────────────────────────────────────────────────────────────────

CORAL_SERVER_URL=http://localhost:5555

# ── Legacy (kept for backward compat) ────────────────────────────────────────

AMOUNT_SOL=0.0001
