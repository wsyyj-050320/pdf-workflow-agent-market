{
  "name": "agent-server",
  "version": "0.1.0",
  "description": "Node.js HTTP server wrapping TypeScript agent strategies — drop-in replacement for coral-server",
  "type": "module",
  "scripts": {
    "dev": "node node_modules/tsx/dist/cli.mjs watch src/index.ts",
    "build": "tsc",
    "start": "node dist/index.js",
    "typecheck": "tsc --noEmit",
    "test": "vitest run"
  },
  "dependencies": {
    "cors": "^2.8.5",
    "express": "^4.19.2"
  },
  "devDependencies": {
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/node": "^20.12.0",
    "@types/supertest": "^6.0.0",
    "supertest": "^7.0.0",
    "tsx": "^4.7.3",
    "typescript": "^5.4.5",
    "vitest": "^1.6.0"
  }
}
